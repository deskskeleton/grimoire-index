---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'A comprehensive catalog of magic systems in fiction.' } = Astro.props;
const fullTitle = title === 'The Grimoire Index' ? title : `${title} — The Grimoire Index`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{fullTitle}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="min-h-screen flex flex-col">
    <header class="border-b border-[var(--color-rule)] dark:border-[var(--color-rule-dark)]">
      <div class="max-w-6xl mx-auto px-6 py-5 flex items-center justify-between gap-6 flex-wrap">
        <a href="/" class="!no-underline flex items-baseline gap-2">
          <span class="font-sans font-bold text-xl tracking-tight">The Grimoire Index</span>
          <span class="text-xs text-[var(--color-muted)] hidden sm:inline">a catalog of magic systems</span>
        </a>
        <nav class="flex items-center gap-5 text-sm font-sans">
          <a href="/browse" class="!text-inherit hover:!text-[var(--color-accent)]">Browse</a>
          <a href="/taxonomy" class="!text-inherit hover:!text-[var(--color-accent)]">Taxonomy</a>
          <a href="/compare" class="!text-inherit hover:!text-[var(--color-accent)]">Compare</a>
          <a href="/about" class="!text-inherit hover:!text-[var(--color-accent)]">About</a>
        </nav>
      </div>
    </header>
    <main class="flex-1 max-w-6xl mx-auto px-6 py-10 w-full">
      <slot />
    </main>
    <footer class="border-t border-[var(--color-rule)] dark:border-[var(--color-rule-dark)] mt-16">
      <div class="max-w-6xl mx-auto px-6 py-6 text-sm text-[var(--color-muted)] flex justify-between flex-wrap gap-4">
        <span>The Grimoire Index — original analytical writing about fictional magic systems.</span>
        <a href="/about" class="!text-[var(--color-muted)]">Editorial policy</a>
      </div>
    </footer>
  </body>
</html>
